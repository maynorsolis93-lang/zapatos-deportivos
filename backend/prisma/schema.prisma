generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  fullName     String
  email        String    @unique
  passwordHash String
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  inventoryMovements InventoryMovement[]
  orderStatusHistory OrderStatusHistory[]
}

model Category {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  label     String
  createdAt DateTime @default(now())
  products  Product[]
}

model Audience {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  label     String
  createdAt DateTime @default(now())
  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String?  @unique
  name        String
  description String?
  // CAMBIO AQUÍ: De Float a Decimal
  basePrice   Decimal  @default(0) @db.Decimal(12, 2)
  badge       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId Int
  audienceId Int
  category   Category @relation(fields: [categoryId], references: [id])
  audience   Audience @relation(fields: [audienceId], references: [id])

  images   ProductImage[]
  variants ProductVariant[]
  orderItems OrderItem[]

  @@index([isActive])
  @@index([categoryId])
  @@index([audienceId])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Size {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  sortOrder Int      @default(0)
  variants  ProductVariant[]
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  stockQty    Int      @default(0)
  reservedQty Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productId Int
  sizeId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      Size    @relation(fields: [sizeId], references: [id])

  inventoryMovements InventoryMovement[]
  orderItems          OrderItem[]

  @@unique([productId, sizeId])
  @@index([productId])
  @@index([stockQty])
}

model InventoryMovement {
  id            Int      @id @default(autoincrement())
  movementType  String
  quantity      Int
  reason        String
  referenceType String?
  referenceId   Int?
  note          String?
  createdAt     DateTime @default(now())

  variantId Int
  createdBy Int?
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  admin     AdminUser?      @relation(fields: [createdBy], references: [id])

  @@index([variantId, createdAt(sort: Desc)])
}

model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String
  city      String?
  address   String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id        Int      @id @default(autoincrement())
  status    String   @default("pending")
  source    String   @default("web")
  // CAMBIOS AQUÍ: De Float a Decimal
  subtotal  Decimal  @default(0) @db.Decimal(12, 2)
  discount  Decimal  @default(0) @db.Decimal(12, 2)
  total     Decimal  @default(0) @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([status, createdAt(sort: Desc)])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int
  // CAMBIOS AQUÍ: De Float a Decimal
  unitPrice Decimal  @db.Decimal(12, 2)
  lineTotal Decimal  @db.Decimal(12, 2)

  orderId   Int
  productId Int
  variantId Int
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model OrderStatusHistory {
  id         Int      @id @default(autoincrement())
  oldStatus  String?
  newStatus  String
  changedAt  DateTime @default(now())
  note       String?

  orderId    Int
  changedBy  Int?
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin      AdminUser? @relation(fields: [changedBy], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}