# ============================================
# KIRO SHOES - VARIABLES DE ENTORNO PRODUCCIÓN
# ============================================

# ============================================
# BASE DE DATOS
# ============================================
# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/database?schema=public
DATABASE_URL="postgresql://usuario:password@host:5432/kiro_inventory?schema=public"

# ============================================
# JWT SECRETS
# ============================================
# IMPORTANTE: Generar secrets seguros de 256 bits mínimo
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Secret para access tokens (1 hora de duración)
JWT_SECRET="tu_secreto_jwt_super_seguro_256_bits_minimo_aqui"

# Secret para refresh tokens (7 días de duración)
JWT_REFRESH_SECRET="tu_secreto_refresh_diferente_256_bits_minimo_aqui"

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
# Entorno de ejecución
NODE_ENV="production"

# Puerto del servidor (Railway/Heroku usan PORT automático)
PORT=3000

# ============================================
# CORS
# ============================================
# Orígenes permitidos (separados por coma)
# Ejemplo: https://tu-dominio.com,https://www.tu-dominio.com
ALLOWED_ORIGINS="https://tu-dominio.com,https://www.tu-dominio.com"

# ============================================
# RATE LIMITING
# ============================================
# Ventana de tiempo en milisegundos (15 minutos = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Máximo de requests por ventana
RATE_LIMIT_MAX_REQUESTS=100

# Máximo de intentos de login por ventana (15 minutos)
LOGIN_MAX_ATTEMPTS=5

# ============================================
# LOGGING
# ============================================
# Nivel de logs: error, warn, info, debug
LOG_LEVEL="info"

# ============================================
# MONITOREO (OPCIONAL)
# ============================================
# Sentry DSN para tracking de errores
# SENTRY_DSN="https://tu-sentry-dsn@sentry.io/proyecto"

# ============================================
# EMAIL (OPCIONAL - PARA FUTURAS FUNCIONALIDADES)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="tu-email@gmail.com"
# SMTP_PASSWORD="tu-password-de-aplicacion"
# SMTP_FROM="Kiro Shoes <noreply@kiroshoes.com>"

# ============================================
# BACKUP (OPCIONAL)
# ============================================
# DB_BACKUP_ENABLED=true
# DB_BACKUP_SCHEDULE="0 2 * * *"  # Cron: Diario a las 2 AM
# DB_BACKUP_RETENTION_DAYS=30

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commitear este archivo con valores reales a Git
# 2. Usar variables de entorno del proveedor de hosting
# 3. Rotar secrets periódicamente (cada 90 días)
# 4. Mantener backup de las variables de entorno
# 5. Usar secrets diferentes para staging y producción
